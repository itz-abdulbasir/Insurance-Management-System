class RoleButton(QPushButton):
    def __init__(self, label, icon, parent=None):
        super().__init__(parent)
        self.setCheckable(True)
        self.setCursor(QCursor(Qt.CursorShape.PointingHandCursor))
        self.setFixedHeight(44)
        self.setText(f"{icon}  {label}")
        self._refresh(False)
        self.toggled.connect(self._refresh)

    def _refresh(self, active):
        if active:
            self.setStyleSheet(f"""
                QPushButton {{
                    background: {T.ROLE_ACTIVE_BG};
                    border: 2px solid {T.ROLE_ACTIVE_BD};
                    border-radius: 10px;
                    color: {T.ROLE_ACTIVE_FG};
                    font-size: 12px;
                    font-weight: 700;
                    font-family: 'Segoe UI', sans-serif;
                }}
            """)
        else:
            self.setStyleSheet(f"""
                QPushButton {{
                    background: {T.WHITE};
                    border: 2px solid {T.ROLE_IDLE_BD};
                    border-radius: 10px;
                    color: {T.ROLE_IDLE_FG};
                    font-size: 12px;
                    font-weight: 600;
                    font-family: 'Segoe UI', sans-serif;
                }}
                QPushButton:hover {{
                    border-color: #C9CEED;
                    color: {T.NAVY};
                    background: #F8F9FF;
                }}
            """)


# ──────────────────────────────────────────────────────────────
#  STYLED INPUT
# ──────────────────────────────────────────────────────────────
class StyledInput(QLineEdit):
    def __init__(self, placeholder="", password=False, parent=None):
        super().__init__(parent)
        self.setPlaceholderText(placeholder)
        self.setFixedHeight(48)
        if password:
            self.setEchoMode(QLineEdit.EchoMode.Password)
        self._refresh(False)

    def focusInEvent(self, e):
        self._refresh(True)
        super().focusInEvent(e)

    def focusOutEvent(self, e):
        self._refresh(False)
        super().focusOutEvent(e)

    def _refresh(self, focused):
        border = T.BORDER_FOCUS if focused else T.BORDER
        self.setStyleSheet(f"""
            QLineEdit {{
                border: 1.5px solid {border};
                border-radius: 10px;
                padding: 0 14px;
                font-size: 13px;
                color: {T.NAVY};
                background: {T.WHITE};
                font-family: 'Segoe UI', sans-serif;
            }}
        """)


# ──────────────────────────────────────────────────────────────
#  BACKGROUND (soft radial glow blobs)
# ──────────────────────────────────────────────────────────────
class BgCanvas(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.setAttribute(Qt.WidgetAttribute.WA_TransparentForMouseEvents)

    def paintEvent(self, _):
        p = QPainter(self)
        p.setRenderHint(QPainter.RenderHint.Antialiasing)
        p.fillRect(self.rect(), QBrush(QColor(T.BG)))

        # top-right blue blob
        g1 = QRadialGradient(self.width() * 0.88, self.height() * 0.12, 240)
        g1.setColorAt(0.0, QColor(67, 97, 238, 30))
        g1.setColorAt(1.0, QColor(67, 97, 238, 0))
        p.setBrush(QBrush(g1))
        p.setPen(Qt.PenStyle.NoPen)
        p.drawEllipse(int(self.width() * 0.88) - 240, int(self.height() * 0.12) - 240, 480, 480)

        # bottom-left purple blob
        g2 = QRadialGradient(self.width() * 0.08, self.height() * 0.88, 200)
        g2.setColorAt(0.0, QColor(124, 111, 255, 22))
        g2.setColorAt(1.0, QColor(124, 111, 255, 0))
        p.setBrush(QBrush(g2))
        p.drawEllipse(int(self.width() * 0.08) - 200, int(self.height() * 0.88) - 200, 400, 400)


