# ──────────────────────────────────────────────────────────────
#  DATABASE AUTH
# ──────────────────────────────────────────────────────────────
DB_CONFIG = {
    "host":     "localhost",
    "port":     3306,
    "database": "insurance_db",
    "user":     "app_user",
    "password": "your_password",
}

def authenticate_user(email: str, password: str, role: str):
    """
    Checks MySQL for user with matching email + role, then bcrypt-verifies password.
    Falls back to demo credentials if DB is not yet connected.
    """
    try:
        conn   = mysql.connector.connect(**DB_CONFIG)
        cursor = conn.cursor(dictionary=True)
        cursor.execute(
            "SELECT * FROM users WHERE email = %s AND role = %s AND is_active = 1",
            (email, role.lower())
        )
        user = cursor.fetchone()
        cursor.close()
        conn.close()
        if user and bcrypt.checkpw(password.encode(), user["password"].encode()):
            return user
        return None
    except Error:
        return _demo_auth(email, password, role)


def _demo_auth(email, password, role):
    """Demo logins when MySQL is not yet set up."""
    DEMO = {
        "Admin":    ("admin@ims.com",    "admin123"),
        "Agent":    ("agent@ims.com",    "agent123"),
        "Customer": ("customer@ims.com", "cust123"),
    }
    if role in DEMO:
        d_email, d_pass = DEMO[role]
        if email == d_email and password == d_pass:
            return {"id": 1, "full_name": f"Demo {role}", "email": email, "role": role.lower()}
    return None


# ──────────────────────────────────────────────────────────────
#  SESSION SINGLETON
# ──────────────────────────────────────────────────────────────
class CurrentSession:
    _user = None

    @classmethod
    def start(cls, user: dict):
        cls._user = user

    @classmethod
    def get(cls):
        return cls._user

    @classmethod
    def role(cls):
        return cls._user["role"] if cls._user else None

    @classmethod
    def clear(cls):
        cls._user = None


