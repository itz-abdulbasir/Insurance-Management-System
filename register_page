DB_CONFIG = {
    "host": "localhost", "port": 3306,
    "database": "insurance_db",
    "user": "app_user", "password": "your_password",
}

def register_user(data: dict) -> tuple:
    """Returns (True, 'success') or (False, 'error message')."""
    try:
        conn   = mysql.connector.connect(**DB_CONFIG)
        cursor = conn.cursor()
        cursor.execute("SELECT id FROM users WHERE email = %s", (data["email"],))
        if cursor.fetchone():
            return False, "An account with this email already exists."
        hashed = bcrypt.hashpw(data["password"].encode(), bcrypt.gensalt()).decode()
        cursor.execute("""
            INSERT INTO users (full_name, email, password, role, is_active, created_at)
            VALUES (%s, %s, %s, %s, 1, NOW())
        """, (data["full_name"], data["email"], hashed, data["role"].lower()))
        user_id = cursor.lastrowid
        if data["role"].lower() == "customer":
            cursor.execute("""
                INSERT INTO clients (user_id, agent_id, full_name, dob, phone, email, address, created_at)
                VALUES (%s, 1, %s, %s, %s, %s, %s, NOW())
            """, (user_id, data["full_name"], data.get("dob"), data.get("phone",""),
                  data["email"], data.get("address","")))
        conn.commit(); cursor.close(); conn.close()
        return True, "success"
    except Error as e:
        print(f"[DEMO] DB not connected ({e}) — would register {data['email']} as {data['role']}")
        return True, "demo"


