        lay.addLayout(_col("Reporting To", self.admin_sup))

        lay.addStretch()
        return p

    def set_role(self, role: str):
        self._role = role
        self.stack.setCurrentIndex({"Customer":0,"Agent":1,"Admin":2}.get(role, 0))
        heads = {
            "Customer": ("Policy Preferences",  "Complete your insurance profile"),
            "Agent":    ("Agent Details",        "Provide your professional information"),
            "Admin":    ("Admin Details",         "Set up your administrator profile"),
        }
        self.title.setText(heads[role][0])
        self.sub.setText(heads[role][1])

    def validate(self):
        if self._role == "Agent":
            self.license_no.set_error(False); self.branch.set_error(False)
            if not self.license_no.text().strip():
                self.license_no.set_error(True)
                return False, "Insurance license number is required for agents."
            if not self.branch.text().strip():
                self.branch.set_error(True)
                return False, "Please enter your branch or office."
        return True, ""

    def get_data(self):
        if self._role == "Customer":
            return {
                "policy_interest":   self.policy_type.currentText(),
                "occupation":        self.occupation.text().strip(),
                "beneficiary_name":  self.bene_name.text().strip(),
                "beneficiary_rel":   self.bene_rel.currentText(),
                "emg_name":          self.emg_name.text().strip(),
                "emg_phone":         self.emg_phone.text().strip(),
            }
        elif self._role == "Agent":
            return {
                "license_number":    self.license_no.text().strip(),
                "branch":            self.branch.text().strip(),
                "specialization":    self.specialization.currentText(),
                "commission_rate":   self.commission.text().strip(),
                "experience":        self.experience.currentText(),
                "supervisor":        self.supervisor.text().strip(),
            }
        else:
            return {
                "department":        self.dept.currentText(),
                "employee_id":       self.emp_id.text().strip(),
                "access_level":      self.access_level.currentText(),
