# ─────────────────────────────────────────────────────
#  REGISTER CARD  (3-step container)
# ─────────────────────────────────────────────────────
class RegisterCard(QFrame):
    register_success = pyqtSignal(str, str)   # full_name, role
    back_to_login    = pyqtSignal()

    def __init__(self, initial_role="Customer", parent=None):
        super().__init__(parent)
        self.setFixedSize(560, 660)
        self.setStyleSheet(f"QFrame {{ background:{T.WHITE}; border-radius:20px; }}")
        shadow = QGraphicsDropShadowEffect(self)
        shadow.setBlurRadius(60); shadow.setXOffset(0); shadow.setYOffset(16)
        shadow.setColor(QColor(67, 97, 238, 40))
        self.setGraphicsEffect(shadow)

        self._step      = 0
        self._data      = {}
        self._init_role = initial_role
        self._build()

    def _build(self):
        root = QVBoxLayout(self)
        root.setContentsMargins(40, 30, 40, 26); root.setSpacing(0)

        # ── Brand + back link ──
        top = QHBoxLayout()
        shield = QLabel("🛡️"); shield.setFixedSize(36, 36)
        shield.setAlignment(Qt.AlignmentFlag.AlignCenter)
        shield.setStyleSheet(f"background:qlineargradient(x1:0,y1:0,x2:1,y2:1,"
                             f"stop:0 {T.BLUE},stop:1 {T.BLUE_LIGHT});"
                             f"border-radius:10px; font-size:15px;")
        brand = QLabel(f"<span style='color:{T.NAVY};font-weight:800;'>Shield</span>"
                       f"<span style='color:{T.BLUE};font-weight:700;'>YourInsurance</span>")
        brand.setTextFormat(Qt.TextFormat.RichText)
        brand.setStyleSheet("font-size:12px; font-family:'Segoe UI';")
        bk = QPushButton("← Login")
        bk.setCursor(QCursor(Qt.CursorShape.PointingHandCursor))
        bk.setStyleSheet(f"QPushButton{{background:transparent;border:none;"
                         f"color:{T.MUTED};font-size:11px;font-weight:600;font-family:'Segoe UI';}}"
                         f"QPushButton:hover{{color:{T.BLUE};}}")
        bk.clicked.connect(self.back_to_login.emit)
        top.addWidget(shield); top.addSpacing(8); top.addWidget(brand)
        top.addStretch(); top.addWidget(bk)
        root.addLayout(top); root.addSpacing(20)

        # ── Stepper ──
        self.stepper = StepIndicator()
        root.addWidget(self.stepper); root.addSpacing(18)

        # ── Divider ──
        div = QFrame(); div.setFixedHeight(1)
        div.setStyleSheet(f"background:{T.BORDER};")
        root.addWidget(div); root.addSpacing(18)

        # ── Step pages ──
        self.s1 = Step1Account()
        self.s2 = Step2Personal()
        self.s3 = Step3Details()
        self.s1._set_role(self._init_role)
        self.s3.set_role(self._init_role)

        self.pages = QStackedWidget()
        self.pages.addWidget(self.s1)
        self.pages.addWidget(self.s2)
        self.pages.addWidget(self.s3)
        root.addWidget(self.pages); root.addSpacing(16)

        # ── Error label ──
        self.err = QLabel("")
        self.err.setWordWrap(True)
        self.err.setStyleSheet(f"color:{T.ERROR}; font-size:11px; font-family:'Segoe UI';"
                               f"background:rgba(229,88,88,0.08);"
                               f"border:1px solid rgba(229,88,88,0.2);"
                               f"border-radius:8px; padding:7px 10px;")
        self.err.hide(); root.addWidget(self.err)

        # ── Nav ──
        nav = QHBoxLayout()
        self.back_btn = QPushButton("← Back")
        self.back_btn.setFixedHeight(46)
        self.back_btn.setCursor(QCursor(Qt.CursorShape.PointingHandCursor))
        self.back_btn.setStyleSheet(f"""QPushButton {{
                background:{T.WHITE}; border:1.5px solid {T.BORDER};
                border-radius:10px; color:{T.NAVY};
                font-size:13px; font-weight:700; font-family:'Segoe UI'; padding:0 24px;}}
            QPushButton:hover {{border-color:{T.BLUE}; color:{T.BLUE}; background:#F8F9FF;}}""")
        self.back_btn.hide()
        self.back_btn.clicked.connect(self._prev)

        self.next_btn = QPushButton("Continue  →")
        self.next_btn.setFixedHeight(46)
        self.next_btn.setCursor(QCursor(Qt.CursorShape.PointingHandCursor))
        self.next_btn.setStyleSheet(f"""QPushButton {{
                background:qlineargradient(x1:0,y1:0,x2:1,y2:0,
                    stop:0 {T.BLUE},stop:1 {T.BLUE_LIGHT});
                color:white; border:none; border-radius:10px;
                font-size:13px; font-weight:700; font-family:'Segoe UI'; letter-spacing:0.4px;}}
            QPushButton:hover {{
                background:qlineargradient(x1:0,y1:0,x2:1,y2:0,
                    stop:0 {T.BLUE_DARK},stop:1 {T.BLUE});}}
            QPushButton:disabled {{background:#C5CAE9; color:white;}}""")
        sh = QGraphicsDropShadowEffect(); sh.setBlurRadius(18); sh.setOffset(0,6)
        sh.setColor(QColor(67,97,238,70)); self.next_btn.setGraphicsEffect(sh)
        self.next_btn.clicked.connect(self._next)
        nav.addWidget(self.back_btn); nav.addStretch(); nav.addWidget(self.next_btn)
        root.addSpacing(4); root.addLayout(nav); root.addSpacing(10)

        # ── Sign-in link ──
        sign = QHBoxLayout()
        sign.addStretch()
        sign.addWidget(QLabel(f"<span style='color:{T.MUTED};font-size:12px;'>"
                              f"Already have an account?</span>").also(
                                  lambda l: l.setTextFormat(Qt.TextFormat.RichText)))
        si = QPushButton("Sign in")
        si.setCursor(QCursor(Qt.CursorShape.PointingHandCursor))
        si.setStyleSheet(f"QPushButton{{background:transparent;border:none;"
                         f"color:{T.BLUE};font-size:12px;font-weight:700;"
                         f"font-family:'Segoe UI';padding:0;}}"
                         f"QPushButton:hover{{color:{T.BLUE_DARK};}}")
        si.clicked.connect(self.back_to_login.emit)
        sign.addSpacing(4); sign.addWidget(si); sign.addStretch()
        root.addLayout(sign)

    # ── Step navigation ──
    def _next(self):
        self.err.hide()
        if self._step == 0:
            ok, msg = self.s1.validate()
            if not ok: return self._show_err(msg)
            self._data.update(self.s1.get_data())
            self.s3.set_role(self._data["role"])
        elif self._step == 1:
            ok, msg = self.s2.validate()
            if not ok: return self._show_err(msg)
            self._data.update(self.s2.get_data())
        elif self._step == 2:
            ok, msg = self.s3.validate()
            if not ok: return self._show_err(msg)
            self._data.update(self.s3.get_data())
            self._submit(); return

        self._step += 1; self._go(self._step)

    def _prev(self):
        self.err.hide(); self._step -= 1; self._go(self._step)

    def _go(self, step):
        self.pages.setCurrentIndex(step)
        self.stepper.set_step(step)
        self.back_btn.setVisible(step > 0)
        self.next_btn.setText("Create Account  ✓" if step == 2 else "Continue  →")

    def _submit(self):
        self.next_btn.setText("Creating account…"); self.next_btn.setEnabled(False)
        QTimer.singleShot(300, self._do_register)

    def _do_register(self):
        ok, msg = register_user(self._data)
        self.next_btn.setText("Create Account  ✓"); self.next_btn.setEnabled(True)
        if ok:
            self.register_success.emit(self._data.get("full_name","User"),
                                       self._data.get("role","Customer"))
        else:
            self._show_err(msg); self._step = 0; self._go(0)

    def _show_err(self, msg):
        self.err.setText(f"⚠  {msg}"); self.err.show()


# Tiny helper so QLabel chain works inline
QLabel.also = lambda self, fn: (fn(self), self)[1]


# ─────────────────────────────────────────────────────
#  BACKGROUND CANVAS
# ─────────────────────────────────────────────────────
class BgCanvas(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.setAttribute(Qt.WidgetAttribute.WA_TransparentForMouseEvents)

    def paintEvent(self, _):
        p = QPainter(self); p.setRenderHint(QPainter.RenderHint.Antialiasing)
        p.fillRect(self.rect(), QBrush(QColor(T.BG)))
        g1 = QRadialGradient(self.width()*.9, self.height()*.1, 260)
        g1.setColorAt(0, QColor(67,97,238,25)); g1.setColorAt(1, QColor(67,97,238,0))
        p.setBrush(QBrush(g1)); p.setPen(Qt.PenStyle.NoPen)
        p.drawEllipse(int(self.width()*.9)-260, int(self.height()*.1)-260, 520, 520)
        g2 = QRadialGradient(self.width()*.05, self.height()*.9, 200)
        g2.setColorAt(0, QColor(124,111,255,20)); g2.setColorAt(1, QColor(124,111,255,0))
        p.setBrush(QBrush(g2))
        p.drawEllipse(int(self.width()*.05)-200, int(self.height()*.9)-200, 400, 400)


