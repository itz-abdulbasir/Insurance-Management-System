class StepIndicator(QWidget):
    LABELS = ["Account", "Personal", "Details"]

    def __init__(self, parent=None):
        super().__init__(parent)
        self.setFixedHeight(58)
        self._step = 0
        self._dots = []; self._lines = []; self._lbls = []
        layout = QHBoxLayout(self)
        layout.setContentsMargins(0, 0, 0, 0); layout.setSpacing(0)

        for i, name in enumerate(self.LABELS):
            dot = QLabel(str(i+1))
            dot.setFixedSize(28, 28)
            dot.setAlignment(Qt.AlignmentFlag.AlignCenter)
            lbl = QLabel(name)
            lbl.setAlignment(Qt.AlignmentFlag.AlignCenter)
            self._dots.append(dot); self._lbls.append(lbl)

            col = QVBoxLayout(); col.setSpacing(4)
            col.setAlignment(Qt.AlignmentFlag.AlignHCenter)
            col.addWidget(dot, 0, Qt.AlignmentFlag.AlignHCenter)
            col.addWidget(lbl, 0, Qt.AlignmentFlag.AlignHCenter)
            w = QWidget(); w.setLayout(col)
            layout.addWidget(w)

            if i < len(self.LABELS) - 1:
                line = QFrame(); line.setFixedHeight(2)
                line.setSizePolicy(QSizePolicy.Policy.Expanding, QSizePolicy.Policy.Fixed)
                self._lines.append(line); layout.addWidget(line)

        self._refresh()

    def set_step(self, step):
        self._step = step; self._refresh()

    def _refresh(self):
        for i, (dot, lbl) in enumerate(zip(self._dots, self._lbls)):
            done   = i < self._step
            active = i == self._step
            dot.setText("✓" if done else str(i+1))
            if done or active:
                glow = "border:3px solid rgba(67,97,238,0.25);" if active else ""
                dot.setStyleSheet(f"background:{T.BLUE}; color:white; border-radius:14px;"
                                  f"font-size:11px; font-weight:800; font-family:'Segoe UI'; {glow}")
                lbl.setStyleSheet(f"color:{T.NAVY}; font-size:10px; font-weight:700; font-family:'Segoe UI';")
            else:
                dot.setStyleSheet(f"background:#EEF0F6; color:{T.MUTED}; border-radius:14px;"
                                  f"font-size:11px; font-weight:800; font-family:'Segoe UI';")
                lbl.setStyleSheet(f"color:{T.MUTED}; font-size:10px; font-weight:600; font-family:'Segoe UI';")
        for i, line in enumerate(self._lines):
            c = T.BLUE if i < self._step else "#EEF0F6"
            line.setStyleSheet(f"background:{c}; border-radius:1px;")


