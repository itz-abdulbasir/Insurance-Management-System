class FieldLabel(QLabel):
    def __init__(self, text, parent=None):
        super().__init__(text, parent)
        self.setStyleSheet(f"color:{T.NAVY}; font-size:11px; font-weight:700;"
                           f"font-family:'Segoe UI'; letter-spacing:0.3px;")


class StyledInput(QLineEdit):
    def __init__(self, placeholder="", password=False, parent=None):
        super().__init__(parent)
        self.setPlaceholderText(placeholder)
        self.setFixedHeight(44)
        if password:
            self.setEchoMode(QLineEdit.EchoMode.Password)
        self._err = False
        self._apply(False)

    def focusInEvent(self, e):  self._apply(True);  super().focusInEvent(e)
    def focusOutEvent(self, e): self._apply(False); super().focusOutEvent(e)

    def set_error(self, v: bool):
        self._err = v; self._apply(self.hasFocus())

    def _apply(self, focused):
        b = T.ERROR if self._err else (T.BORDER_FOCUS if focused else T.BORDER)
        self.setStyleSheet(f"""
            QLineEdit {{
                border:1.5px solid {b}; border-radius:9px;
                padding:0 13px; font-size:13px; color:{T.NAVY};
                background:{T.WHITE}; font-family:'Segoe UI';
            }}
        """)


