class Step1Account(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self._selected_role = "Customer"
        self._role_btns = {}
        self._build()

    def _build(self):
        lay = QVBoxLayout(self)
        lay.setContentsMargins(0, 0, 0, 0); lay.setSpacing(0)

        t = QLabel("Create your account")
        t.setStyleSheet(f"color:{T.NAVY}; font-size:19px; font-weight:800; font-family:'Segoe UI';")
        s = QLabel("Choose your role and set up your login credentials")
        s.setStyleSheet(f"color:{T.MUTED}; font-size:12px; font-family:'Segoe UI';")
        lay.addWidget(t); lay.addSpacing(3); lay.addWidget(s); lay.addSpacing(18)

        # Role selector
        lay.addWidget(FieldLabel("I am registering as")); lay.addSpacing(6)
        row = QHBoxLayout(); row.setSpacing(8)
        for role, icon in [("Customer","📋"), ("Agent","👤"), ("Admin","⚙️")]:
            btn = QPushButton(f"{icon}  {role}")
            btn.setCheckable(True); btn.setFixedHeight(42)
            btn.setCursor(QCursor(Qt.CursorShape.PointingHandCursor))
            btn.setChecked(role == "Customer")
            btn.clicked.connect(lambda _, r=role: self._set_role(r))
            self._role_btns[role] = btn
            self._style_btn(btn, role == "Customer")
            row.addWidget(btn)
        lay.addLayout(row); lay.addSpacing(16)

        self.email = StyledInput("you@email.com")
        lay.addLayout(_col("Email Address", self.email)); lay.addSpacing(11)

        self.username = StyledInput("e.g. johndoe92")
        lay.addLayout(_col("Username", self.username)); lay.addSpacing(11)

        # Password with eye toggle
        self.pwd = StyledInput("Minimum 8 characters", password=True)
        self.pwd.setStyleSheet(self.pwd.styleSheet() +
                               "border-right:none; border-radius:9px 0 0 9px;")
        self.eye = QPushButton("👁")
        self.eye.setFixedSize(44, 44)
        self.eye.setCursor(QCursor(Qt.CursorShape.PointingHandCursor))
        self.eye.setStyleSheet(f"""
            QPushButton {{ background:{T.WHITE}; border:1.5px solid {T.BORDER};
                border-left:none; border-radius:0 9px 9px 0;
                font-size:14px; color:{T.MUTED}; }}
            QPushButton:hover {{ background:#F8F9FF; color:{T.NAVY}; }}
        """)
        self.eye.clicked.connect(self._toggle)
        pwd_row = QHBoxLayout(); pwd_row.setSpacing(0)
        pwd_row.addWidget(self.pwd); pwd_row.addWidget(self.eye)
        lay.addWidget(FieldLabel("Password")); lay.addSpacing(5)
        lay.addLayout(pwd_row); lay.addSpacing(11)

        self.cpwd = StyledInput("Re-enter your password", password=True)
        lay.addLayout(_col("Confirm Password", self.cpwd))
        lay.addStretch()

    def _set_role(self, role):
        self._selected_role = role
        for r, b in self._role_btns.items():
            b.setChecked(r == role); self._style_btn(b, r == role)

    def _style_btn(self, btn, active):
        if active:
            btn.setStyleSheet(f"""QPushButton {{ background:{T.ROLE_ACTIVE_BG};
                border:2px solid {T.ROLE_ACTIVE_BD}; border-radius:9px;
                color:{T.ROLE_ACTIVE_FG}; font-size:12px; font-weight:700;
                font-family:'Segoe UI'; }}""")
        else:
            btn.setStyleSheet(f"""QPushButton {{ background:{T.WHITE};
                border:2px solid {T.ROLE_IDLE_BD}; border-radius:9px;
                color:{T.ROLE_IDLE_FG}; font-size:12px; font-weight:600;
                font-family:'Segoe UI'; }}
                QPushButton:hover {{ border-color:#C9CEED; color:{T.NAVY}; background:#F8F9FF; }}""")

    def _toggle(self):
        if self.pwd.echoMode() == QLineEdit.EchoMode.Password:
            self.pwd.setEchoMode(QLineEdit.EchoMode.Normal); self.eye.setText("🙈")
        else:
            self.pwd.setEchoMode(QLineEdit.EchoMode.Password); self.eye.setText("👁")

    def validate(self):
        for w in [self.email, self.username, self.pwd, self.cpwd]:
            w.set_error(False)
        e = self.email.text().strip()
        if not e or not re.match(r"[^@]+@[^@]+\.[^@]+", e):
            self.email.set_error(True); return False, "Please enter a valid email address."
        if len(self.username.text().strip()) < 3:
            self.username.set_error(True); return False, "Username must be at least 3 characters."
        if len(self.pwd.text()) < 8:
            self.pwd.set_error(True); return False, "Password must be at least 8 characters."
        if self.pwd.text() != self.cpwd.text():
            self.cpwd.set_error(True); return False, "Passwords do not match."
        return True, ""

    def get_data(self):
        return {"role": self._selected_role,
                "email": self.email.text().strip(),
                "username": self.username.text().strip(),
                "password": self.pwd.text()}


