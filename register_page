class RegisterWindow(QWidget):
    back_to_login = pyqtSignal()

    def __init__(self, role="Customer", parent=None):
        super().__init__(parent)
        self.setWindowTitle("ShieldYourInsurance — Register")
        self.setFixedSize(680, 740)

        self.bg = BgCanvas(self); self.bg.setGeometry(0, 0, 680, 740)

        self.card = RegisterCard(initial_role=role, parent=self)
        self.card.move((680-560)//2, (740-660)//2)
        self.card.register_success.connect(self._on_success)
        self.card.back_to_login.connect(self.back_to_login.emit)

        self.setWindowOpacity(0.0)
        self._anim = QPropertyAnimation(self, b"windowOpacity")
        self._anim.setDuration(400); self._anim.setStartValue(0.0)
        self._anim.setEndValue(1.0); self._anim.setEasingCurve(QEasingCurve.Type.OutCubic)

    def showEvent(self, e):
        super().showEvent(e); self._anim.start()

    def _on_success(self, name: str, role: str):
        icons = {"Customer":"📋","Agent":"👤","Admin":"⚙️"}
        msg = QMessageBox(self)
        msg.setWindowTitle("Registration Successful!")
        msg.setText(
            f"<b style='font-size:15px;'>{icons.get(role,'🎉')} &nbsp;Welcome, {name}!</b><br/><br/>"
            f"Your <b style='color:{T.BLUE};'>{role}</b> account has been created.<br/>"
            f"You can now sign in with your credentials.<br/><br/>"
            f"<small style='color:{T.MUTED};'>Returning to login…</small>"
        )
        msg.setTextFormat(Qt.TextFormat.RichText); msg.exec()
        self.back_to_login.emit()


